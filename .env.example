# Copy to .env and fill in values
# For EC2: copy your local .env or Render env vars

NODE_ENV=production
PORT=5000

# === Database (required) ===
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# === Session (required) ===
SESSION_SECRET=your_random_32_char_secret_here

# === Razorpay (required for payments) ===
# For local testing: use Test keys (rzp_test_...) from Razorpay Dashboard → API Keys → Generate Test Key
# Test card: 4111 1111 1111 1111 | any future expiry | any CVV
# Put your keys here or in .env (app loads .env.example then .env; .env overrides)
RAZORPAY_KEY_ID=rzp_test_SM4iz8s6rWWaQm
RAZORPAY_KEY_SECRET=7gHaznDBD5Et9oCuoFBui35V

# === Google OAuth (optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://toodlesfunzone.com/api/auth/google/callback

# === SMTP / Email (optional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=admin@toodlesfunzone.com
ADMIN_PHONE=+919901218980

# === Cloudinary (optional, for media uploads) ===
CLOUDINARY_CLOUDNAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === WhatsApp Business API (optional) ===
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TOODLES_WHATSAPP_NUMBER=+919901218980

# === Google Analytics (optional, baked into frontend at build) ===
VITE_GA_MEASUREMENT_ID=
